# --- Docker Compose local ---
POSTGRES_PASSWORD=postgres

# Token da API https://brapi.dev (Dashboard -> API Keys).
# Sem token, recursos que dependem de cotacao podem falhar.
BRAPI_TOKEN=

# Chave usada para assinar tokens JWT. Em producao/testes publicos, use string longa e secreta.
JWT_KEY=dev-only-change-this-secret-key-with-at-least-32-characters

# --- Deploy gratuito (Neon + Render + Vercel) ---
# Render (API .NET):
#   ConnectionStrings__DefaultConnection=Host=<neon-host>;Database=<db>;Username=<user>;Password=<senha>;Ssl Mode=Require;Trust Server Certificate=true
#   Jwt__Key=<segredo-forte>
#   Brapi__Token=<seu-token>
#   Cors__Origins__0=https://<frontend>.vercel.app
# (demais vars - ASPNETCORE_ENVIRONMENT, Jwt__Issuer, Jwt__Audience etc. - estao em render.yaml)
#
# Vercel (frontend):
#   VITE_API_URL=https://<api>.onrender.com/api
#
# Guia completo: docs/DEPLOY-FREE.md
